# ============================================================
# CAAS - Configuration
# ============================================================
# Copiez ce fichier en `.env` et ajustez les valeurs selon vos besoins.
# Toutes les variables sont optionnelles (des valeurs par défaut existent).
#
# Format : CAAS_<NOM_VARIABLE>=<valeur>
# ============================================================

# --- Rate Limiting ---
# Nombre max de requêtes par fenêtre glissante
CAAS_RATE_LIMIT_MAX_REQUESTS=30

# Durée de la fenêtre en secondes
CAAS_RATE_LIMIT_WINDOW_SECONDS=60

# Activer le rate limiting (false en dev, true en prod)
CAAS_RATE_LIMIT_ENABLED=true

# --- Task Manager ---
# Concurrence max (0 = auto-détection CPU)
CAAS_TASK_MAX_CONCURRENT=0

# Taille max de la file d'attente
CAAS_TASK_MAX_QUEUE_SIZE=20

# Durée de conservation des résultats (secondes)
CAAS_TASK_RESULT_TTL_SECONDS=1800

# Intervalle de nettoyage (secondes)
CAAS_TASK_CLEANUP_INTERVAL_SECONDS=60

# --- Upload ---
# Taille max d'un fichier en Mo
CAAS_MAX_FILE_SIZE_MB=50

# --- Batch / Multi-Upload ---
# Nombre max de fichiers par requête batch
CAAS_MAX_FILES_PER_REQUEST=10

# Taille totale max de tous les fichiers dans un batch (Mo)
CAAS_MAX_TOTAL_SIZE_MB=100

# Nombre max de tâches async soumises par batch (doit être >= MAX_FILES_PER_REQUEST)
CAAS_MAX_TASKS_PER_REQUEST=10

# --- OCR ---
# Langues Tesseract (ex: fra+eng, eng, deu+eng)
CAAS_OCR_LANGUAGES=fra+eng

# Zoom pour le rendu PDF → image (doit être un entier, 4 ≈ 300 DPI)
CAAS_OCR_SCALE=4

# --- CORS ---
# Origines autorisées (séparées par des virgules). Vide = pas de CORS (same-origin uniquement).
CAAS_CORS_ORIGINS=

# Autoriser les credentials (cookies, headers d'authentification)
CAAS_CORS_ALLOW_CREDENTIALS=false

# Durée de cache du preflight en secondes
CAAS_CORS_MAX_AGE=600

# --- Serveur ---
CAAS_HOST=0.0.0.0
CAAS_PORT=8000
CAAS_RELOAD=false
