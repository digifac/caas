# ============================================================
# Authelia + Nginx + CAAS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# Domain
# -----------------------------------------------------------
# Your domain name (e.g., caas.example.com)
DOMAIN=caas.example.com

# -----------------------------------------------------------
# Let's Encrypt
# -----------------------------------------------------------
# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@example.com

# -----------------------------------------------------------
# Authelia
# -----------------------------------------------------------
# Issuer for TOTP (2FA) — shown in authenticator apps
AUTHELIA_DUAL_FACTOR_TOTP_ISSUER=CAAS

# Disable password reset (recommended for local users)
AUTHELIA_PASSWORD_RESET_DISABLE=true

# -----------------------------------------------------------
# Authelia — SMTP (optional, for 2FA backup codes)
# Uncomment if you want email notifications
# AUTHELIA_NOTIFIER_SMTP_HOST=smtp.example.com
# AUTHELIA_NOTIFIER_SMTP_PORT=587
# AUTHELIA_NOTIFIER_SMTP_USERNAME=authelia@example.com
# AUTHELIA_NOTIFIER_SMTP_PASSWORD=smtp-password
# AUTHELIA_NOTIFIER_SMTP_SENDER=noreply@example.com

# -----------------------------------------------------------
# CAAS — CORS (optional)
# Uncomment if you need CORS for a frontend app
# CAAS_CORS_ORIGINS=https://app.example.com
# CAAS_CORS_ALLOW_CREDENTIALS=true
