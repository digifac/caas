#!/usr/bin/env bash
# Pre-commit hook: linting, type checking, and auto-increment version in pyproject.toml
# Runs on EVERY commit - no manual intervention needed
# Uses --no-reinstall to avoid pip operations during git commit

# Get the repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
PYPROJECT="$REPO_ROOT/pyproject.toml"
BUMP_SCRIPT="$REPO_ROOT/bump_version.py"

# Determine Python executable from virtual environment
if [ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
    PYTHON="$REPO_ROOT/.venv/Scripts/python.exe"
elif [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python"
else
    PYTHON="python"
fi

# Determine ruff executable from virtual environment
if [ -x "$REPO_ROOT/.venv/Scripts/ruff.exe" ]; then
    RUFF="$REPO_ROOT/.venv/Scripts/ruff.exe"
elif [ -x "$REPO_ROOT/.venv/bin/ruff" ]; then
    RUFF="$REPO_ROOT/.venv/bin/ruff"
else
    RUFF="ruff"
fi

# Determine mypy executable from virtual environment
if [ -x "$REPO_ROOT/.venv/Scripts/mypy.exe" ]; then
    MYPY="$REPO_ROOT/.venv/Scripts/mypy.exe"
elif [ -x "$REPO_ROOT/.venv/bin/mypy" ]; then
    MYPY="$REPO_ROOT/.venv/bin/mypy"
else
    MYPY="mypy"
fi

# Run ruff check (linting + auto-fix)
echo "🔍 Running ruff check..."
"$RUFF" check . --fix
if [ $? -ne 0 ]; then
    echo "❌ Ruff found errors. Please fix them before committing."
    exit 1
fi

# Run mypy type checking
echo "🔍 Running mypy type checking..."
"$MYPY" app/
if [ $? -ne 0 ]; then
    echo "❌ Mypy found type errors. Please fix them before committing."
    exit 1
fi

# Auto-increment version in pyproject.toml (only once per commit workflow)
# This prevents excessive version bumps when making multiple commits.
if [ -f "$BUMP_SCRIPT" ]; then
    # Check if pyproject.toml is already staged or modified in the working tree
    # If it's already changed, skip bumping to avoid overwriting manual changes
    # and prevent double-bumping within the same commit workflow.
    STAGED_CHANGES=$(git diff --cached --name-only 2>/dev/null)
    WORKING_CHANGES=$(git diff --name-only 2>/dev/null)
    
    PYPROJECT_CHANGED=false
    
    # Check if pyproject.toml is in staged changes
    echo "$STAGED_CHANGES" | grep -q "pyproject.toml" && PYPROJECT_CHANGED=true
    
    # Check if pyproject.toml is in working tree changes
    echo "$WORKING_CHANGES" | grep -q "pyproject.toml" && PYPROJECT_CHANGED=true
    
    if [ "$PYPROJECT_CHANGED" = true ]; then
        echo "⏭️  Skipping version bump — pyproject.toml already modified in this commit workflow."
    else
        echo "🔄 Auto-bumping version..."
        "$PYTHON" "$BUMP_SCRIPT" --no-reinstall
        
        # Stage the updated pyproject.toml
        git add "$PYPROJECT"
    fi
fi

exit 0
